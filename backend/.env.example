# ===========================================
# GlobalLeads Backend 环境变量配置
# ===========================================

# Database - PostgreSQL
DATABASE_URL=postgresql+asyncpg://globaleads:globaleads_dev@localhost:5432/globaleads

# Redis
REDIS_URL=redis://localhost:6379/1

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# AI Provider: ollama 或 deepseek
AI_PROVIDER=ollama

# Ollama 配置（AI_PROVIDER=ollama 时使用）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:0.6b

# DeepSeek 配置（AI_PROVIDER=deepseek 时使用）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# JWT 认证
JWT_SECRET=change-this-to-a-random-secret-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=72

# Reddit API
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=GlobalLeads/1.0

# Bluesky API
BLUESKY_HANDLE=
BLUESKY_PASSWORD=

# YouTube Data API v3
YOUTUBE_API_KEY=

# Google Custom Search API（免费 100 次/天）
# https://developers.google.com/custom-search/v1/overview
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
